<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="flex-grow w-full">
    
    <!-- Hero / About Intro Section -->
    <section class="bg-gradient-to-br from-teal-50 via-white to-white py-16 md:py-24 relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 flex flex-col md:flex-row items-center gap-12">
            <!-- Left Text -->
            <div class="w-full md:w-1/2">
                <span class="inline-block py-1.5 px-4 rounded-full bg-white text-teal-600 text-sm font-semibold tracking-wide mb-6 border border-teal-100 shadow-sm">
                    About Our Clinic
                </span>
                <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-800 mb-6 leading-tight">
                    We provide trusted care for your <span class="text-teal-500">health and beauty</span>
                </h1>
                <p class="text-lg text-slate-500 font-light leading-relaxed max-w-lg mb-8">
                    Our mission is to bring top-tier medical expertise combined with world-class facilities. Experience personalized wellness in a setting designed for you.
                </p>
                <div class="flex gap-4">
                    <a href="#who-we-are" class="px-6 py-3 rounded-lg bg-teal-50 text-teal-600 font-semibold hover:bg-teal-100 transition">
                        Discover More
                    </a>
                </div>
            </div>
            <!-- Right Image -->
            <div class="w-full md:w-1/2 relative">
                <div class="absolute inset-0 bg-teal-200 rounded-full blur-3xl opacity-30 transform translate-x-10 -translate-y-10"></div>
                <img src="/images/doctor_hero.png" alt="Our Medical Team" class="relative z-10 w-full max-w-md mx-auto aspect-[4/3] object-cover rounded-[2rem] shadow-2xl shadow-slate-200/50 border-8 border-white transform hover:scale-[1.02] transition duration-500">
            </div>
        </div>
    </section>

    <!-- About Content Section -->
    <section id="who-we-are" class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col-reverse md:flex-row items-center gap-16">
            <!-- Left Image -->
            <div class="w-full md:w-1/2 relative">
                <div class="absolute -inset-4 bg-teal-50 rounded-[2.5rem] transform -rotate-3 z-0"></div>
                <img src="/images/laser_therapy.png" alt="Modern Clinic" class="relative z-10 w-full aspect-square object-cover rounded-3xl shadow-lg border border-slate-100">
            </div>
            <!-- Right Text -->
            <div class="w-full md:w-1/2">
                <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-6">Who We Are</h2>
                <div class="space-y-4 text-slate-500 font-light leading-relaxed">
                    <p>
                        Established with a vision to redefine aesthetic and healthcare standards, SkinCare Clinic integrates advanced technology with compassionate care. Our globally recognized specialists are devoted to providing outcomes that inspire confidence.
                    </p>
                    <p>
                        We operate on principles of transparency, high-quality medical grade treatments, and prioritizing patient safety above all. From diagnostic consultations to customized surgical routines, we are your partners in wellness.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 md:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                
                <div class="bg-white p-8 rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 hover:-translate-y-1 transition transform duration-300">
                    <div class="w-12 h-12 bg-teal-50 text-teal-500 rounded-xl flex items-center justify-center mb-6">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-2">Experienced Doctors</h3>
                    <p class="text-slate-500 text-sm font-light leading-relaxed">Renowned specialists delivering masterclass results.</p>
                </div>
                
                <div class="bg-white p-8 rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 hover:-translate-y-1 transition transform duration-300">
                    <div class="w-12 h-12 bg-teal-50 text-teal-500 rounded-xl flex items-center justify-center mb-6">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-2">Advanced Equipment</h3>
                    <p class="text-slate-500 text-sm font-light leading-relaxed">State-of-the-art machinery for precise care.</p>
                </div>

                <div class="bg-white p-8 rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 hover:-translate-y-1 transition transform duration-300">
                    <div class="w-12 h-12 bg-teal-50 text-teal-500 rounded-xl flex items-center justify-center mb-6">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-2">Personalized Care</h3>
                    <p class="text-slate-500 text-sm font-light leading-relaxed">Tailored treatments fitting your unique profile.</p>
                </div>

                <div class="bg-white p-8 rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 hover:-translate-y-1 transition transform duration-300">
                    <div class="w-12 h-12 bg-teal-50 text-teal-500 rounded-xl flex items-center justify-center mb-6">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-2">24/7 Support</h3>
                    <p class="text-slate-500 text-sm font-light leading-relaxed">Round the clock assistance for our patients.</p>
                </div>

            </div>
        </div>
    </section>

    <!-- Statistics Section -->
    <section class="py-16 md:py-24 bg-white border-y border-slate-100">
        <div class="max-w-7xl mx-auto px-4 md:px-8">
            <div class="flex flex-col md:flex-row justify-center items-center gap-12 md:gap-32 text-center">
                
                <div>
                    <h4 class="text-4xl md:text-5xl font-extrabold text-teal-500 mb-2">10+</h4>
                    <p class="text-slate-600 font-medium tracking-wide">Years Experience</p>
                </div>
                
                <div class="hidden md:block w-px h-16 bg-slate-200"></div>
                
                <div>
                    <h4 class="text-4xl md:text-5xl font-extrabold text-teal-500 mb-2">5000+</h4>
                    <p class="text-slate-600 font-medium tracking-wide">Happy Patients</p>
                </div>
                
                <div class="hidden md:block w-px h-16 bg-slate-200"></div>

                <div>
                    <h4 class="text-4xl md:text-5xl font-extrabold text-teal-500 mb-2">50+</h4>
                    <p class="text-slate-600 font-medium tracking-wide">Expert Doctors</p>
                </div>

            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 md:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-4">Meet Our Doctors</h2>
                <p class="text-lg text-slate-500 max-w-2xl mx-auto font-light">Leading experts certified to provide the highest standard of specialized care.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                
                <!-- Doctor Card 1 -->
                <div class="bg-white rounded-[24px] overflow-hidden shadow-sm hover:shadow-lg transition duration-300 border border-slate-100">
                    <img src="/images/doctor_hero.png" alt="Dr. Sarah Jenkins" class="w-full h-72 object-cover object-top pb-4 pt-4 px-4 rounded-[2rem]">
                    <div class="p-6 text-center">
                        <h3 class="text-xl font-bold text-slate-800 mb-1">Dr. Sarah Jenkins</h3>
                        <p class="text-teal-600 text-sm font-semibold mb-4">Chief Dermatologist</p>
                       
                    </div>
                </div>

                <!-- Doctor Card 2 -->
                <div class="bg-white rounded-[24px] overflow-hidden shadow-sm hover:shadow-lg transition duration-300 border border-slate-100">
                    <img src="/images/hair_transplant.png" alt="Dr. Michael Chang" class="w-full h-72 object-cover object-top pb-4 pt-4 px-4 rounded-[2rem]">
                    <div class="p-6 text-center">
                        <h3 class="text-xl font-bold text-slate-800 mb-1">Dr. Michael Chang</h3>
                        <p class="text-teal-600 text-sm font-semibold mb-4">Hair Restoration Spec.</p>
                       
                    </div>
                </div>

                <!-- Doctor Card 3 -->
                <div class="bg-white rounded-[24px] overflow-hidden shadow-sm hover:shadow-lg transition duration-300 border border-slate-100">
                    <img src="/images/anti_aging.png" alt="Dr. Emily Rose" class="w-full h-72 object-cover object-top pb-4 pt-4 px-4 rounded-[2rem]">
                    <div class="p-6 text-center">
                        <h3 class="text-xl font-bold text-slate-800 mb-1">Dr. Emily Rose</h3>
                        <p class="text-teal-600 text-sm font-semibold mb-4">Lead Orthodontist</p>
                       
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Call To Action Section -->
    <div class="px-4 md:px-8 bg-slate-50 pb-16">
        <section class="max-w-6xl mx-auto bg-gradient-to-r from-teal-500 to-teal-600 py-16 md:py-24 rounded-[2rem] shadow-xl relative overflow-hidden text-center">
            <!-- SVG curves background for visual flavor -->
            <div class="absolute inset-0 z-0 opacity-10">
                <svg class="h-full w-full object-cover text-white" preserveAspectRatio="none" fill="currentColor" viewBox="0 0 100 100"><path d="M0,50 C30,10 70,90 100,50 L100,100 L0,100 Z"></path></svg>
            </div>
            <div class="relative z-10 max-w-2xl mx-auto px-4">
                <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">Book your appointment today</h2>
                <p class="text-teal-50 text-lg mb-10 font-light max-w-lg mx-auto">Experience our premier facilities. Our dedicated support team is available immediately to arrange your consultation.</p>
                <a href="/auth/login" class="inline-block px-10 py-4 rounded-xl bg-white text-teal-600 font-bold text-lg hover:shadow-lg hover:bg-slate-50 transition transform hover:-translate-y-1">
                    Book Now
                </a>
            </div>
        </section>
    </div>

</main>

<%- include('partials/footer') %>