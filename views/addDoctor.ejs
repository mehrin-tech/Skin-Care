<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-4 font-sans">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-lg border border-slate-100 p-8">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-slate-800">Add New Doctor</h1>
            <p class="text-slate-500 mt-2">Administrative creation interface.</p>
        </div>

        <form action="/doctors/add" method="POST" class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Doctor Name</label>
                <input type="text" name="name" required placeholder="Dr. Jane Doe"
                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition">
            </div>
            
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Department</label>
                <select name="department" required class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-white">
                    <option value="" disabled selected>Select Specialization...</option>
                    <option value="Hair">Hair</option>
                    <option value="Skin">Skin</option>
                    <option value="Dentistry">Dentistry</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Years of Experience</label>
                <input type="number" name="experience" min="0" required placeholder="5"
                    class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition">
            </div>

            <button type="submit" 
                class="w-full py-3 px-4 bg-teal-600 hover:bg-teal-700 text-white font-medium rounded-lg shadow-sm transition duration-150 ease-in-out mt-4">
                Create Doctor Profile
            </button>
        </form>

        <p class="mt-6 text-center">
            <a href="/doctors" class="text-sm font-medium text-slate-500 hover:text-slate-800 transition">← Cancel</a>
        </p>
    </div>
</body>
</html>
