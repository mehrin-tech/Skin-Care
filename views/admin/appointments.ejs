<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans antialiased text-slate-800 flex h-screen overflow-hidden">

    <!-- Left Sidebar -->
    <aside class="w-64 bg-teal-900 border-r border-teal-800 hidden md:flex flex-col flex-shrink-0 text-white">
        <div class="h-16 flex items-center px-6 border-b border-teal-800 bg-teal-950 relative z-10">
            <span class="text-lg font-semibold tracking-wide flex items-center gap-3">
                <div class="bg-teal-700/50 p-1.5 rounded border border-teal-600/50">
                    <svg class="w-5 h-5 text-teal-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                Admin Dashboard
            </span>
        </div>
        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
            <a href="/admin/dashboard" class="flex items-center px-4 py-3 text-sm font-medium rounded text-teal-100 hover:bg-teal-800 hover:text-white transition">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Dashboard
            </a>
            <a href="/admin/patients" class="flex items-center px-4 py-3 text-sm font-medium rounded text-teal-100 hover:bg-teal-800 hover:text-white transition">
                <svg class="w-5 h-5 mr-3 text-teal-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                Patients
            </a>
            <a href="/admin/doctors" class="flex items-center px-4 py-3 text-sm font-medium rounded text-teal-100 hover:bg-teal-800 hover:text-white transition">
                <svg class="w-5 h-5 mr-3 text-teal-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                Doctors
            </a>
            <a href="/admin/appointments" class="flex items-center px-4 py-3 text-sm font-medium rounded bg-teal-700 text-white transition hover:bg-teal-600">
                <svg class="w-5 h-5 mr-3 text-teal-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                Appointments
            </a>
        </nav>
        <div class="p-4 border-t border-teal-800">
            <a href="/auth/logout" class="flex items-center px-4 py-3 text-sm font-medium rounded text-red-200 hover:bg-teal-800 hover:text-white transition">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                Sign out
            </a>
        </div>
    </aside>

    <main class="flex-1 flex flex-col h-full overflow-y-auto bg-slate-50">
        <!-- Top Navbar -->
        <header class="bg-white border-b border-gray-200 h-16 flex items-center justify-between px-6 lg:px-10 sticky top-0 z-20">
            <h2 class="text-xl font-medium text-slate-800">Appointment Manager</h2>
            <div class="flex items-center gap-4">
                <div class="h-8 w-8 rounded bg-teal-100 flex items-center justify-center text-teal-700 font-bold border border-teal-200">
                    <%= user && user.name ? user.name.charAt(0) : 'A' %>
                </div>
                <div class="hidden sm:flex flex-col">
                     <span class="text-sm font-medium text-slate-800"><%= user && user.name ? user.name : 'Admin' %></span>
                </div>
                <form action="/auth/logout" method="GET" class="m-0 sm:hidden">
                    <button type="submit" class="text-sm font-medium text-gray-500 hover:text-red-500 transition">Logout</button>
                </form>
            </div>
        </header>

        <div class="w-full p-6 md:p-10 space-y-6">
            
            <!-- Filter Options Block -->
            <div class="bg-white rounded border border-gray-200 p-6 flex flex-col md:flex-row items-center gap-4">
                <h4 class="font-medium text-slate-800 flex items-center shrink-0">
                    <svg class="w-5 h-5 mr-2 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                    Filter Appointments:
                </h4>
                <form method="GET" action="/admin/appointments" class="flex flex-1 flex-col sm:flex-row gap-3 w-full">
                    <input type="date" name="date" value="<%= query.date || '' %>" class="border border-gray-300 p-2 rounded bg-white text-sm focus:border-teal-500 focus:ring-1 focus:ring-teal-500 outline-none flex-1 transition">
                    <select name="status" class="border border-gray-300 p-2 rounded bg-white text-sm focus:border-teal-500 focus:ring-1 focus:ring-teal-500 outline-none flex-1 transition">
                        <option value="">All Statuses</option>
                        <option value="pending" <%= query.status === 'pending' ? 'selected' : '' %>>Pending</option>
                        <option value="completed" <%= query.status === 'completed' ? 'selected' : '' %>>Completed</option>
                        <option value="cancelled" <%= query.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                    <button type="submit" class="bg-teal-600 hover:bg-teal-700 text-white px-6 py-2 rounded text-sm font-medium transition">Apply Filter</button>
                    <a href="/admin/appointments" class="bg-white hover:bg-gray-50 text-slate-600 px-6 py-2 rounded text-sm font-medium border border-gray-300 transition text-center">Reset</a>
                </form>
            </div>

            <div class="bg-white rounded border border-gray-200 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-gray-200 text-sm text-slate-600">
                                <th class="px-6 py-3.5 font-medium">Patient</th>
                                <th class="px-6 py-3.5 font-medium">Doctor</th>
                                <th class="px-6 py-3.5 font-medium">Date</th>
                                <th class="px-6 py-3.5 font-medium">Status</th>
                                <th class="px-6 py-3.5 font-medium text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 text-sm">
                            <% if (appointments.length === 0) { %>
                                <tr><td colspan="5" class="px-6 py-10 text-center text-slate-500">No appointments found matching this filter.</td></tr>
                            <% } %>
                            <% appointments.forEach(a => { %>
                            <tr class="hover:bg-slate-50 transition-colors bg-white">
                                <td class="px-6 py-4 font-medium text-slate-800"><%= a.userId?.name || 'Unknown' %></td>
                                <td class="px-6 py-4 text-slate-600">Dr. <%= a.doctorId?.name || 'Unknown' %></td>
                                <td class="px-6 py-4 text-slate-600"><%= new Date(a.date).toLocaleString([], { dateStyle: 'medium', timeStyle: 'short' }) %></td>
                                <td class="px-6 py-4">
                                    <form action="/admin/appointments/status/<%= a._id %>" method="POST" class="m-0">
                                        <select name="status" class="border border-gray-300 rounded px-2 py-1 text-xs bg-white text-slate-700 outline-none focus:border-teal-500 focus:ring-1 focus:ring-teal-500 transition" onchange="this.form.submit()">
                                            <option value="pending" <%= a.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                            <option value="completed" <%= a.status === 'completed' ? 'selected' : '' %>>Completed</option>
                                            <option value="cancelled" <%= a.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                        </select>
                                    </form>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <form id="deleteForm-<%= a._id %>" action="/admin/appointments/delete/<%= a._id %>" method="POST" class="inline m-0">
                                        <button type="button" onclick="openDeleteModal('<%= a._id %>')" class="inline-flex items-center px-3 py-1.5 bg-white text-red-600 hover:bg-red-50 rounded text-xs font-medium transition border border-red-200">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- Custom Tailwind Delete Modal -->
    <div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center">
        <!-- Overlay -->
        <div id="modalOverlay" class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity opacity-0" onclick="closeDeleteModal()"></div>
        
        <!-- Modal Content -->
        <div id="modalPanel" class="bg-white rounded-xl shadow-2xl w-full max-w-sm mx-4 relative transform transition-all scale-95 opacity-0 duration-200 border border-slate-100">
            <div class="p-6">
                <!-- Icon -->
                <div class="flex items-center justify-center w-14 h-14 mx-auto bg-red-50 rounded-full mb-5 border border-red-100">
                    <svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                </div>
                
                <h3 class="text-xl font-bold text-center text-slate-800 mb-2">Delete Appointment?</h3>
                <p class="text-sm text-center text-slate-500 mb-8 leading-relaxed">Are you absolutely sure you want to delete this appointment? This action cannot be undone.</p>
                
                <div class="flex gap-3 justify-center">
                    <button type="button" onclick="closeDeleteModal()" class="px-5 py-2.5 bg-white text-slate-600 border border-slate-300 rounded-lg font-medium hover:bg-slate-50 transition flex-1 shadow-sm">
                        Cancel
                    </button>
                    <button type="button" id="confirmDeleteBtn" class="px-5 py-2.5 bg-red-600 text-white border border-transparent rounded-lg font-medium hover:bg-red-700 transition flex-1 shadow-sm shadow-red-500/30">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Interaction Scripts -->
    <script>
        let currentAppointmentId = null;
        
        function openDeleteModal(id) {
            currentAppointmentId = id;
            const modal = document.getElementById('deleteModal');
            const overlay = document.getElementById('modalOverlay');
            const panel = document.getElementById('modalPanel');
            
            // Show modal container
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            // Trigger entrance animations shortly after unhiding (forces reflow)
            setTimeout(() => {
                overlay.classList.remove('opacity-0');
                overlay.classList.add('opacity-100');
                
                panel.classList.remove('scale-95', 'opacity-0');
                panel.classList.add('scale-100', 'opacity-100');
            }, 10);
        }
        
        function closeDeleteModal() {
            const overlay = document.getElementById('modalOverlay');
            const panel = document.getElementById('modalPanel');
            
            // Trigger exit animations
            overlay.classList.remove('opacity-100');
            overlay.classList.add('opacity-0');
            
            panel.classList.remove('scale-100', 'opacity-100');
            panel.classList.add('scale-95', 'opacity-0');
            
            // Hide modal container after animation finishes
            setTimeout(() => {
                const modal = document.getElementById('deleteModal');
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                currentAppointmentId = null;
            }, 200);
        }
        
        // Handle the final delete confirmation
        document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
            if (currentAppointmentId) {
                // Submit the form dynamically corresponding to this specific instance
                document.getElementById('deleteForm-' + currentAppointmentId).submit();
            }
        });
    </script>
</body>
</html>
