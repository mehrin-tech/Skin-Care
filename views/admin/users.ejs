<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans antialiased text-slate-800 flex h-screen overflow-hidden">
    <% const currentPg = locals.currentPage || 1; const totalPgs = locals.totalPages || 1; %>
    <!-- Left Sidebar Navigation -->
    <aside class="w-64 bg-indigo-900 border-r border-indigo-800 hidden md:flex flex-col flex-shrink-0 shadow-lg text-white">
        <div class="h-16 flex items-center px-6 border-b border-indigo-800 bg-indigo-950 shadow-sm relative z-10">
            <span class="text-xl font-extrabold tracking-wider flex items-center gap-3">
                <div class="bg-indigo-600/50 p-1.5 rounded-lg border border-indigo-500/50">
                    <svg class="w-6 h-6 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                Clinic Admin
            </span>
        </div>
        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
            <a href="/admin/dashboard" class="flex items-center px-4 py-3 text-sm font-medium rounded-xl text-indigo-300 hover:bg-indigo-800 hover:text-white transition-all hover:pl-5">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Dashboard
            </a>
            <a href="/admin/patients" class="flex items-center px-4 py-3.5 text-sm font-semibold rounded-xl bg-indigo-800 text-white shadow-md border border-indigo-700/50 transform transition hover:-translate-y-0.5">
                <svg class="w-5 h-5 mr-3 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                Users Table
            </a>
            <a href="/admin/doctors" class="flex items-center px-4 py-3 text-sm font-medium rounded-xl text-indigo-300 hover:bg-indigo-800 hover:text-white transition-all hover:pl-5">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                Doctors
            </a>
            <a href="/admin/appointments" class="flex items-center px-4 py-3 text-sm font-medium rounded-xl text-indigo-300 hover:bg-indigo-800 hover:text-white transition-all hover:pl-5">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                Appointments
            </a>
        </nav>
        <div class="p-4 border-t border-indigo-800/50 bg-indigo-900/30">
            <a href="/auth/logout" class="flex items-center px-4 py-3 text-sm font-medium rounded-xl text-red-300 hover:bg-indigo-800 hover:text-white transition-colors border border-transparent hover:border-red-900/50">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                Secure Logout
            </a>
        </div>
    </aside>

    <main class="flex-1 flex flex-col h-full overflow-y-auto bg-slate-50/50">
        <!-- Top Navbar -->
        <header class="bg-white border-b border-slate-200 h-16 flex items-center justify-between px-6 lg:px-10 sticky top-0 z-20 shadow-sm backdrop-blur-sm bg-white/90">
            <div class="flex items-center">
                <h2 class="text-xl font-bold text-slate-800 tracking-tight leading-5">Identity Schema Manager</h2>
            </div>
            <div class="flex items-center gap-4">
                <span class="hidden sm:block text-sm font-medium text-slate-500">Welcome back, <strong class="text-indigo-600"><%= user && user.name ? user.name : 'Admin' %></strong></span>
                <form action="/auth/logout" method="GET" class="m-0">
                    <button type="submit" class="text-sm font-semibold text-slate-500 hover:text-red-500 transition-colors flex items-center gap-2 bg-slate-100 hover:bg-red-50 px-3 py-1.5 rounded-lg border border-slate-200 hover:border-red-200">
                        <span class="hidden sm:inline">Logout</span>
                    </button>
                </form>
            </div>
        </header>

        <!-- <div class="w-full max-w-6xl mx-auto p-6 md:p-10 space-y-6">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden flex flex-col">
                <div class="px-6 py-5 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
                    <div>
                        <h3 class="text-lg font-bold text-slate-800">Paginated Core Identities</h3>
                        <p class="text-sm text-slate-500">Track and alter universal system bounds safely processing robust database chunks.</p>
                    </div>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="bg-white border-b border-slate-200 text-[11px] uppercase tracking-wider text-slate-500">
                                <th class="px-6 py-4 font-bold">Standard Identity</th>
                                <th class="px-6 py-4 font-bold">Global Email Vector</th>
                                <th class="px-6 py-4 font-bold">Native Security Role</th>
                                <th class="px-6 py-4 font-bold text-center">Data Interventions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                            <% if(!locals.users || locals.users.length === 0) { %>
                                <tr><td colspan="4" class="px-6 py-8 text-center text-slate-500 font-medium">No valid objects returned matching bounds.</td></tr>
                            <% } else { %>
                                <% users.forEach(u => { %>
                                <tr class="hover:bg-indigo-50/30 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center font-bold text-xs"><%= u.name.charAt(0) %></div>
                                            <span class="font-bold text-slate-800"><%= u.name %></span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-slate-500 text-sm font-medium"><%= u.email %></td>
                                    <td class="px-6 py-4">
                                        <form action="/admin/users/role/<%= u._id %>" method="POST" class="flex items-center">
                                            <select name="role" class="border border-slate-200 rounded px-3 py-1.5 text-xs bg-slate-50 font-bold uppercase tracking-wider text-slate-700 outline-none focus:border-indigo-500 transition shadow-sm cursor-pointer" onchange="this.form.submit()">
                                                <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>Standard User</option>
                                                <option value="doctor" <%= u.role === 'doctor' ? 'selected' : '' %>>Clinic Doctor</option>
                                                <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>System Admin</option>
                                            </select>
                                        </form>
                                    </td>
                                    <td class="px-6 py-4 text-center border-l border-slate-100/50">
                                        <% if(u.role !== 'admin' || u._id.toString() !== user._id.toString()) { %>
                                        <form action="/admin/users/delete/<%= u._id %>" method="POST" class="inline" onsubmit="return confirm('WARNING: Destroying user identity permanently clears db node. Ready?');">
                                            <button type="submit" class="inline-flex items-center px-4 py-1.5 bg-red-50 text-red-600 hover:bg-red-500 hover:text-white rounded-md text-[10px] font-bold transition-colors border border-red-100 uppercase tracking-widest">
                                                Delete Array
                                            </button>
                                        </form>
                                        <% } else { %>
                                            <span class="text-[10px] bg-slate-100 px-3 py-1.5 rounded-md text-slate-400 font-bold uppercase tracking-widest">Admin Locked</span>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                
                <div class="px-6 py-5 border-t border-slate-200 bg-slate-50 flex items-center justify-between">
                    <span class="text-sm text-slate-500 font-medium">Viewing frame <span class="font-bold text-slate-800"><%= currentPg %></span> executing bounds to <span class="font-bold text-slate-800"><%= totalPgs %></span> fully.</span>
                    <div class="flex gap-2">
                        <% if (currentPg > 1) { %>
                            <a href="/admin/users?page=<%= currentPg - 1 %>" class="px-4 py-2 bg-white border border-slate-300 rounded-lg text-xs font-bold hover:bg-slate-100 transition shadow-sm">Retract Window</a>
                        <% } else { %>
                            <span class="px-4 py-2 border border-slate-200 rounded-lg text-xs font-bold text-slate-400 bg-slate-100 cursor-not-allowed shadow-sm">Retract Window</span>
                        <% } %>

                        <% if (currentPg < totalPgs) { %>
                            <a href="/admin/users?page=<%= currentPg + 1 %>" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-xs font-bold hover:bg-indigo-700 transition shadow-md border border-indigo-700">Next Stage</a>
                        <% } else { %>
                            <span class="px-4 py-2 border border-slate-200 rounded-lg text-xs font-bold text-slate-400 bg-slate-100 cursor-not-allowed shadow-sm">Next Stage</span>
                        <% } %>
                    </div>
                </div> -->
 <div class="p-6">
            <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
                <table class="w-full text-left">
                    <thead class="bg-gray-100 border-b border-gray-200 text-gray-600">
                        <tr>
                            <th class="px-6 py-4 font-semibold">Token Number</th>
                            <th class="px-6 py-4 font-semibold">Patient Name</th>
                            <th class="px-6 py-4 font-semibold">Mobile Number</th>
                            <th class="px-6 py-4 font-semibold">Age</th>
                            <th class="px-6 py-4 font-semibold">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% if(!users || users.length === 0) { %>
                            <tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">No patients found.</td></tr>
                        <% } else { %>
                            <% users.forEach((p, index) => { %>
                                <tr class="hover:bg-gray-50 transition-colors <%= index % 2 === 0 ? 'bg-white' : 'bg-gray-50/50' %>">
                                    <td class="px-6 py-4"><%= p.tokenNumber || (index + 1) %></td>
                                    <td class="px-6 py-4 font-medium"><%= p.userId?.name || 'N/A' %></td>
                                    <td class="px-6 py-4"><%= p.userId?.phoneNumber || 'N/A' %></td>
                                    <td class="px-6 py-4"><%= p.userId?.age || 'N/A' %></td>
                                    <td class="px-6 py-4">
                                        <a href="/admin/patients/<%= p._id %>" class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm font-medium transition-colors">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        
        </div>
    </main>
</body>
</html>
