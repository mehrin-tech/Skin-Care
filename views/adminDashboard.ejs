<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-indigo-50 min-h-screen p-4 md:p-8 font-sans">
    <div class="max-w-4xl mx-auto">
        <!-- Admin Header -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 md:p-8 mb-6 flex flex-col md:flex-row justify-between items-start md:items-center">
            <div>
                <h1 class="text-2xl font-bold text-slate-800">Admin Control Center</h1>
                <p class="text-slate-500 mt-1">Logged in as <strong><%= user.name %></strong></p>
            </div>
            <form action="/auth/logout" method="GET" class="mt-4 md:mt-0">
                <button type="submit" class="px-5 py-2.5 bg-slate-800 text-white hover:bg-slate-900 font-medium rounded-lg transition duration-150 shadow-sm border border-transparent">
                     Log Out
                </button>
            </form>
        </div>

        <!-- Management Actions -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <a href="/doctors" class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200 hover:shadow-md hover:border-indigo-300 transition-all flex items-start space-x-4">
                <div class="h-12 w-12 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0">
                    <span class="text-xl">🩺</span>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-800">Manage System Doctors</h3>
                    <p class="text-sm text-slate-500 mt-1">Add, edit, or remove healthcare professionals from the public roster.</p>
                </div>
            </a>
            
            <a href="/appointments" class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200 hover:shadow-md hover:border-indigo-300 transition-all flex items-start space-x-4">
                <div class="h-12 w-12 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0">
                    <span class="text-xl">📊</span>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-800">Browse Global Appointments</h3>
                    <p class="text-sm text-slate-500 mt-1">View the master schedule logging all cross-patient tracking references.</p>
                </div>
            </a>
        </div>
    </div>
</body>
</html>
