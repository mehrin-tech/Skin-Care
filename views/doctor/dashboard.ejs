<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans antialiased text-slate-800 flex h-screen overflow-hidden">

    <!-- Left Sidebar -->
    <aside class="w-64 bg-teal-900 border-r border-teal-800 hidden md:flex flex-col flex-shrink-0 text-white">
        <div class="h-16 flex items-center px-6 border-b border-teal-800 bg-teal-950 relative z-10">
            <span class="text-lg font-semibold tracking-wide flex items-center gap-3">
                <div class="bg-teal-700/50 p-1.5 rounded border border-teal-600/50">
                    <svg class="w-5 h-5 text-teal-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                Doctor Portal
            </span>
        </div>
        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
            <a href="/doctor/dashboard" class="flex items-center px-4 py-3 text-sm font-medium rounded bg-teal-700 text-white transition hover:bg-teal-600">
                <svg class="w-5 h-5 mr-3 text-teal-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Dashboard
            </a>
            <a href="/doctor/appointments" class="flex items-center px-4 py-3 text-sm font-medium rounded text-teal-100 hover:bg-teal-800 hover:text-white transition">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                Appointments
            </a>
            <a href="/doctor/profile" class="flex items-center px-4 py-3 text-sm font-medium rounded text-teal-100 hover:bg-teal-800 hover:text-white transition">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                Profile
            </a>
        </nav>
        <div class="p-4 border-t border-teal-800">
            <a href="/auth/logout" class="flex items-center px-4 py-3 text-sm font-medium rounded text-red-200 hover:bg-teal-800 hover:text-white transition">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                Sign out
            </a>
        </div>
    </aside>

    <main class="flex-1 flex flex-col h-full overflow-y-auto bg-slate-50">
        <!-- Top Navbar -->
        <header class="bg-white border-b border-gray-200 h-16 flex items-center justify-between px-6 lg:px-10 sticky top-0 z-20">
            <h2 class="text-xl font-medium text-slate-800">Dashboard</h2>
            <div class="flex items-center gap-4">
                <div class="h-8 w-8 rounded bg-teal-100 flex items-center justify-center text-teal-700 font-bold border border-teal-200">
                    <%= user && user.name ? user.name.charAt(0) : 'D' %>
                </div>
                <div class="hidden sm:flex flex-col">
                     <span class="text-sm font-medium text-slate-800">Dr. <%= user.name %></span>
                </div>
            </div>
        </header>

        <div class="p-4 md:p-8 space-y-6">

            <!-- Metrics Cards -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                
                <div class="bg-white rounded p-6 border border-gray-200 flex flex-col hover:shadow-md hover:border-teal-300 transition-all">
                    <h3 class="text-sm font-medium text-gray-500 mb-1">Today</h3>
                    <div class="flex items-baseline gap-2 mt-1">
                        <span class="text-3xl font-medium text-slate-800"><%= todayAppointments || 0 %></span>
                    </div>
                </div>

                <div class="bg-white rounded p-6 border border-gray-200 flex flex-col hover:shadow-md hover:border-teal-300 transition-all">
                    <h3 class="text-sm font-medium text-gray-500 mb-1">Pending</h3>
                    <div class="flex items-baseline gap-2 mt-1">
                        <span class="text-3xl font-medium text-slate-800"><%= pendingPatients || 0 %></span>
                    </div>
                </div>

                <div class="bg-white rounded p-6 border border-gray-200 flex flex-col hover:shadow-md hover:border-teal-300 transition-all">
                    <h3 class="text-sm font-medium text-gray-500 mb-1">Completed</h3>
                    <div class="flex items-baseline gap-2 mt-1">
                        <span class="text-3xl font-medium text-slate-800"><%= completedConsultations || 0 %></span>
                    </div>
                </div>

                <div class="bg-white rounded p-6 border border-gray-200 flex flex-col hover:shadow-md hover:border-teal-300 transition-all">
                    <h3 class="text-sm font-medium text-gray-500 mb-1">Total</h3>
                    <div class="flex items-baseline gap-2 mt-1">
                        <span class="text-3xl font-medium text-slate-800"><%= totalAppointments || 0 %></span>
                    </div>
                </div>

            </div>

            <div class="pt-2">
                <h3 class="text-lg font-medium text-slate-800 mb-4">Recent Appointments</h3>
                <div class="bg-white rounded border border-gray-200 overflow-hidden shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead class="bg-slate-50 border-b border-gray-200 text-sm text-slate-600">
                                <tr>
                                    <th class="px-6 py-3.5 font-medium">Patient</th>
                                    <th class="px-6 py-3.5 font-medium">Date</th>
                                    <th class="px-6 py-3.5 font-medium">Contact</th>
                                    <th class="px-6 py-3.5 font-medium">Status</th>
                                    <th class="px-6 py-3.5 font-medium text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 text-sm">
                                <% if (!appointments || appointments.length === 0) { %>
                                    <tr><td colspan="5" class="px-6 py-8 text-center text-slate-500">No recent appointments found.</td></tr>
                                <% } %>
                                <% appointments.forEach(appt => { %>
                                <tr class="hover:bg-slate-50 transition-colors bg-white">
                                    <td class="px-6 py-4 font-medium text-slate-800">
                                        <%= appt.userId?.name || 'Unknown' %>
                                    </td>
                                    <td class="px-6 py-4 text-slate-600">
                                        <%= new Date(appt.date).toLocaleString([], { dateStyle: 'medium', timeStyle: 'short' }) %>
                                    </td>
                                    <td class="px-6 py-4 text-slate-600">
                                        <%= appt.userId?.phoneNumber || 'N/A' %>
                                    </td>
                                    <td class="px-6 py-4">
                                        <% if(appt.status === 'completed') { %>
                                            <span class="inline-flex px-2 py-1 bg-teal-50 text-teal-700 border border-teal-200 rounded text-xs font-medium uppercase tracking-wide">
                                                Completed
                                            </span>
                                        <% } else { %>
                                            <span class="inline-flex px-2 py-1 bg-yellow-50 text-yellow-700 border border-yellow-200 rounded text-xs font-medium uppercase tracking-wide">
                                                Pending
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <a href="/doctor/patient/<%= appt._id %>" class="inline-flex items-center bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded text-xs font-medium transition shadow-sm border border-transparent">
                                            View Details
                                        </a>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </main>

</body>
</html>