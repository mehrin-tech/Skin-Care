<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans antialiased text-slate-800 flex h-screen overflow-hidden">

    <!-- Left Sidebar -->
    <aside class="w-64 bg-teal-900 border-r border-teal-800 hidden md:flex flex-col flex-shrink-0 text-white">
        <div class="h-16 flex items-center px-6 border-b border-teal-800 bg-teal-950 relative z-10">
            <span class="text-lg font-semibold tracking-wide flex items-center gap-3">
                <div class="bg-teal-700/50 p-1.5 rounded border border-teal-600/50">
                    <svg class="w-5 h-5 text-teal-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                Doctor Portal
            </span>
        </div>
        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
            <a href="/doctor/dashboard" class="flex items-center px-4 py-3 text-sm font-medium rounded text-teal-100 hover:bg-teal-800 hover:text-white transition">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Dashboard
            </a>
            <a href="/doctor/appointments" class="flex items-center px-4 py-3 text-sm font-medium rounded text-teal-100 hover:bg-teal-800 hover:text-white transition">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                Appointments
            </a>
            <a href="/doctor/profile" class="flex items-center px-4 py-3 text-sm font-medium rounded bg-teal-700 text-white transition hover:bg-teal-600">
                <svg class="w-5 h-5 mr-3 text-teal-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                Profile
            </a>
        </nav>
        <div class="p-4 border-t border-teal-800">
            <a href="/auth/logout" class="flex items-center px-4 py-3 text-sm font-medium rounded text-red-200 hover:bg-teal-800 hover:text-white transition">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                Sign out
            </a>
        </div>
    </aside>

    <main class="flex-1 flex flex-col h-full overflow-y-auto bg-slate-50">
        <!-- Top Navbar -->
        <header class="bg-white border-b border-gray-200 h-16 flex items-center justify-between px-6 lg:px-10 sticky top-0 z-20">
            <h2 class="text-xl font-medium text-slate-800">Edit Profile</h2>
            <div class="flex items-center gap-4">
                <div class="h-8 w-8 rounded bg-teal-100 flex items-center justify-center text-teal-700 font-bold border border-teal-200">
                    <%= user && user.name ? user.name.charAt(0).toUpperCase() : 'D' %>
                </div>
                <div class="hidden sm:flex flex-col">
                     <span class="text-sm font-medium text-slate-800">Dr. <%= user.name %></span>
                </div>
            </div>
        </header>

        <div class="p-4 md:p-8 flex-1 max-w-3xl mx-auto w-full">
            <form action="/doctor/profile/edit" method="POST" class="bg-white rounded border border-slate-200 shadow-sm overflow-hidden relative">
                
                <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                    <div>
                        <h1 class="text-lg font-semibold text-slate-800">Profile Information</h1>
                        <p class="text-sm text-slate-500 mt-1">Update your professional details appearing on patient portals.</p>
                    </div>
                </div>

                <div class="px-8 py-8 space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-600 mb-2">Name</label>
                        <input type="text" name="name" value="<%= user.name %>" required class="w-full bg-white border border-gray-300 text-slate-900 rounded px-4 py-2.5 text-sm focus:border-teal-500 focus:ring-1 focus:ring-teal-500 outline-none transition">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-slate-600 mb-2">Department</label>
                        <select name="department" class="w-full bg-white border border-gray-300 text-slate-900 rounded px-4 py-2.5 text-sm focus:border-teal-500 focus:ring-1 focus:ring-teal-500 outline-none transition cursor-pointer">
                            <option value="">Select Domain</option>
                            <option value="Skin" <%= user.department === 'Skin' ? 'selected' : '' %>>Skin Specialist</option>
                            <option value="Hair" <%= user.department === 'Hair' ? 'selected' : '' %>>Hair Clinic</option>
                            <option value="Dentistry" <%= user.department === 'Dentistry' ? 'selected' : '' %>>Dentistry</option>
                            <option value="General" <%= user.department === 'General' ? 'selected' : '' %>>General Medicine</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-600 mb-2">Clinical Experience (Years)</label>
                        <input type="number" name="experience" value="<%= user.experience || '' %>" required class="w-full bg-white border border-gray-300 text-slate-900 rounded px-4 py-2.5 text-sm focus:border-teal-500 focus:ring-1 focus:ring-teal-500 outline-none transition">
                    </div>
                </div>
                
                <div class="px-8 py-5 bg-slate-50 border-t border-slate-200 flex justify-end gap-3">
                    <a href="/doctor/profile" class="px-5 py-2 rounded text-sm font-medium text-slate-600 bg-white border border-slate-300 hover:bg-slate-50 transition shadow-sm">Cancel</a>
                    <button type="submit" class="px-5 py-2 bg-teal-600 text-white text-sm font-medium rounded hover:bg-teal-700 transition shadow-sm border border-transparent">
                         Save Changes
                    </button>
                </div>
            </form>
        </div>
    </main>
</body>
</html>
