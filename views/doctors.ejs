<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="flex-grow w-full pb-20 relative bg-slate-50/50">
    <!-- Header Section -->
    <section class="bg-gradient-to-b from-teal-50/80 to-transparent pt-16 pb-12 mb-10 border-b border-slate-100">
        <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="text-left w-full">
                <span class="inline-block py-1.5 px-4 rounded-full bg-white text-teal-600 text-sm font-semibold tracking-wide mb-4 border border-teal-100 shadow-sm">
                    Expert Team
                </span>
                <h1 class="text-4xl md:text-5xl font-bold text-slate-800 mb-4 tracking-tight">Meet Our Specialists</h1>
                <p class="text-lg text-slate-500 max-w-xl font-light">World-class professionals dedicated to your wellbeing.</p>
            </div>
            <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
                <div class="w-full md:w-auto text-left md:text-right">
                    <a href="/admin/add-doctor" class="px-6 py-3.5 bg-white text-teal-600 border border-teal-200 rounded-xl font-semibold shadow-sm hover:shadow-md hover:border-teal-500 transition inline-block">
                        + Add New Doctor
                    </a>
                </div>
            <% } %>
        </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 md:px-8">
        <% if (!doctors || doctors.length === 0) { %>
            <div class="bg-white border border-slate-200 rounded-3xl p-12 md:p-16 text-center shadow-[0_8px_30px_rgb(0,0,0,0.04)] max-w-2xl mx-auto">
                <div class="w-20 h-20 bg-teal-50 text-teal-500 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-teal-100/50">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1z"></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-800 mb-3">No doctors available</h3>
                <p class="text-base text-slate-500 font-light">Please check back later or try selecting a different department.</p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% doctors.forEach(doc => { %>
                    <div class="bg-white rounded-[24px] p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1 border border-slate-100 flex flex-col relative group">
                        
                      

                        <!-- Top Info (Avatar and Details) -->
                        <div class="flex items-center gap-5 mt-2 mb-6">
                            <!-- Avatar using initial -->
                            <div class="w-20 h-20 bg-gradient-to-br from-teal-50 to-teal-100 text-teal-600 rounded-full flex items-center justify-center text-3xl font-bold border-[3px] border-white shadow-sm shrink-0">
                                <%= doc.name ? doc.name.charAt(0).toUpperCase() : 'D' %>
                            </div>
                            
                            <div class="overflow-hidden">
                                <h3 class="text-xl font-bold text-slate-800 mb-2 truncate" title="Dr. <%= doc.name %>">Dr. <%= doc.name %></h3>
                                <div class="flex flex-wrap items-center gap-2 mb-2">
                                    <span class="bg-[#ccfbf1] text-[#0f766e] text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap">
                                        <%= doc.department || 'Specialist' %>
                                    </span>
                                </div>
                                <div class="flex items-center text-yellow-500 text-sm">
                                    <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                    <span class="ml-1 font-semibold text-slate-700">4.8</span>
                                    <span class="text-slate-400 font-light ml-1 text-xs">(120 Reviews)</span>
                                </div>
                            </div>
                        </div>

                        <!-- Stats/Info Row -->
                        <div class="bg-slate-50 rounded-2xl p-4 mb-8 grid grid-cols-2 gap-4 border border-slate-100/50">
                            <div>
                                <p class="text-slate-400 text-xs mb-1 font-medium tracking-wide uppercase">Experience</p>
                                <p class="text-slate-800 font-bold text-sm"><%= doc.experience ? doc.experience + '+ Years' : '5+ Years' %></p>
                            </div>
                            <div>
                                <p class="text-slate-400 text-xs mb-1 font-medium tracking-wide uppercase">Consultation</p>
                                <p class="text-slate-800 font-bold text-sm"><%= doc.fees ? '$' + doc.fees : '$150' %></p>
                            </div>
                        </div>

                        <!-- Actions -->
                          

                    </div>
                <% }) %>
            </div>
        <% } %>

    </div>
</main>

<%- include('partials/footer') %>