<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-[#f0fdfa] flex items-center justify-center min-h-screen p-4 py-8 text-slate-800">

    <div class="max-w-md w-full bg-white rounded-2xl shadow-[0_10px_30px_-10px_rgba(20,184,166,0.12)] overflow-hidden border border-teal-100/60 relative">
        
        <!-- Header -->
        <div class="px-6 py-5 border-b border-teal-50 flex items-center justify-between bg-white relative z-10 shadow-sm">
            <div>
                <h1 class="text-xl font-black text-slate-900 tracking-tight flex items-center gap-2.5">
                    <div class="bg-teal-100 text-teal-600 p-1.5 rounded-lg">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                    </div>
                    Edit Profile
                </h1>
            </div>
            <a href="/profile" class="text-slate-400 hover:text-teal-600 hover:bg-teal-50 transition-all p-2 rounded-lg border border-transparent hover:border-teal-200">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
            </a>
        </div>

        <div class="p-6 bg-slate-50/30">
            <% if (locals.error) { %>
                <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg mb-5 font-bold text-xs border border-red-200 flex items-start gap-3 shadow-sm animate-pulse">
                    <svg class="w-4 h-4 shrink-0 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    <%= error %>
                </div>
            <% } %>

            <form action="/profile/edit" method="POST" class="space-y-4">
                
                <!-- Email (Disabled) -->
                <div>
                    <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5 flex items-center gap-1.5">
                        Registered Email 
                        <svg class="w-2.5 h-2.5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7a4 4 0 00-8 0v4h8z"></path></svg>
                    </label>
                    <input type="email" value="<%= user.email %>" disabled class="w-full bg-slate-100 border border-slate-200 text-slate-400 rounded-lg px-3 py-2 text-sm font-semibold cursor-not-allowed outline-none select-none">
                </div>

                <!-- Name Section -->
                <div>
                    <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Full Name</label>
                    <input type="text" name="name" value="<%= user.name %>" required class="w-full bg-white border border-slate-300 text-slate-900 rounded-lg px-3 py-2 text-sm font-semibold focus:ring-4 focus:ring-teal-500/20 focus:border-teal-500 outline-none transition-all shadow-sm">
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Mobile Number</label>
                        <input type="text" name="phoneNumber" value="<%= user.phoneNumber || '' %>" required placeholder="+1 234-567-8900" class="w-full bg-white border border-slate-300 text-slate-900 rounded-lg px-3 py-2 text-sm font-semibold focus:ring-4 focus:ring-teal-500/20 focus:border-teal-500 outline-none transition-all shadow-sm">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Age</label>
                        <input type="number" name="age" value="<%= user.age || '' %>" placeholder="E.g. 28" class="w-full bg-white border border-slate-300 text-slate-900 rounded-lg px-3 py-2 text-sm font-semibold focus:ring-4 focus:ring-teal-500/20 focus:border-teal-500 outline-none transition-all shadow-sm">
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Gender</label>
                        <select name="gender" class="w-full bg-white border border-slate-300 text-slate-900 rounded-lg px-3 py-2 text-sm font-semibold focus:ring-4 focus:ring-teal-500/20 focus:border-teal-500 outline-none transition-all shadow-sm appearance-none cursor-pointer">
                            <option value="" class="font-medium text-slate-400">Select Gender</option>
                            <option value="Male" <%= user.gender === 'Male' ? 'selected' : '' %> class="font-bold text-slate-900">Male</option>
                            <option value="Female" <%= user.gender === 'Female' ? 'selected' : '' %> class="font-bold text-slate-900">Female</option>
                            <option value="Other" <%= user.gender === 'Other' ? 'selected' : '' %> class="font-bold text-slate-900">Other</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Location / Place</label>
                        <input type="text" name="place" value="<%= user.place || '' %>" placeholder="Enter your place" class="w-full bg-white border border-slate-300 text-slate-900 rounded-lg px-3 py-2 text-sm font-semibold focus:ring-4 focus:ring-teal-500/20 focus:border-teal-500 outline-none transition-all shadow-sm">
                    </div>
                </div>

                <!-- Submit Action Block -->
                <div class="pt-5 mt-3 border-t border-slate-200 flex flex-col-reverse sm:flex-row justify-end gap-3">
                    <a href="/profile" class="px-5 py-2.5 rounded-lg font-bold text-sm text-teal-700 bg-white border-2 border-teal-600 hover:bg-teal-50 transition-all text-center flex-1 sm:flex-none shadow-sm">Back</a>
                    <button type="submit" class="bg-gradient-to-r from-teal-500 to-teal-600 hover:from-teal-600 hover:to-teal-700 text-white px-6 py-2.5 rounded-lg text-sm font-bold shadow-md shadow-teal-500/30 active:scale-[0.98] transition-all text-center flex-1 sm:flex-none flex items-center justify-center gap-1.5">
                        Update
                        <svg class="w-3.5 h-3.5 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    </button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
