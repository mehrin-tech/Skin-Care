<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="flex-grow flex items-center justify-center p-4 w-full py-16">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-sm p-8 text-center border border-slate-200">
        
        <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-red-50 border border-red-100 mb-6">
            <svg class="h-8 w-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
        </div>
        
        <h1 class="text-2xl font-bold text-slate-800 mb-2">
            <%= typeof title !== 'undefined' ? title : 'Error Encountered' %>
        </h1>
        
        <p class="text-sm text-slate-500 mb-8 font-medium">
            <%= typeof message !== 'undefined' ? message : 'Something went wrong.' %>
        </p>

        <% if (process.env.NODE_ENV === 'development' && typeof error !== 'undefined') { %>
            <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl text-left overflow-x-auto text-xs text-slate-600 mb-8 font-mono shadow-inner max-h-64 overflow-y-auto">
                <pre><%= error.stack %></pre>
            </div>
        <% } %>
        
        <a href="/" class="inline-block px-6 py-2.5 bg-teal-500 hover:bg-teal-600 text-white font-semibold rounded-lg shadow-sm transition text-sm">
            Return
        </a>
        
    </div>
</main>

<%- include('partials/footer') %>
