<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Main Layout Wrapper -->
<main class="flex-grow w-full">

    <!-- Hero Section -->
    <section class="relative bg-gradient-to-br from-teal-50 via-white to-white overflow-hidden py-16 md:py-24">
        <!-- Smooth Curve Background (SVG) -->
        <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none shadow-sm pb-px z-0">
            <svg class="relative block w-full h-[60px] md:h-[100px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C79.86,117.82,156.9,114.9,232.5,91.55,263,82.17,292.68,71.05,321.39,56.44Z" fill="#ffffff"></path>
            </svg>
        </div>

        <div class="max-w-6xl mx-auto px-4 md:px-8 flex flex-col md:flex-row items-center gap-12 relative z-10 text-center md:text-left">
            <!-- Left Side Text -->
            <div class="w-full md:w-1/2">
                <span class="inline-block py-1.5 px-4 rounded-full bg-teal-50 text-teal-600 text-sm font-semibold tracking-wide mb-6 border border-teal-100 shadow-sm">
                    Welcome to SkinCare Clinic
                </span>
                <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-800 mb-6 leading-tight">
                    Your <span class="text-teal-500">health</span> <br class="hidden md:block" /> is our priority
                </h1>
                <p class="text-lg text-slate-500 mb-10 max-w-lg font-light leading-relaxed mx-auto md:mx-0">
                    Experience world-class medical care with our top specialists. We blend advanced technology with compassionate care.
                </p>
                <div class="flex flex-col sm:flex-row items-center gap-4 justify-center md:justify-start">
                    <a href="/doctors" class="w-full sm:w-auto px-8 py-3.5 rounded-lg bg-teal-500 hover:bg-teal-600 text-white font-semibold text-lg shadow-lg shadow-teal-500/30 transition transform hover:-translate-y-0.5 text-center">
                        Book Appointment
                    </a>
                    <a href="/services" class="w-full sm:w-auto px-8 py-3.5 rounded-lg bg-white border border-slate-200 hover:border-teal-500 hover:text-teal-500 text-slate-600 font-medium text-lg shadow-sm transition text-center">
                        Our Services
                    </a>
                </div>
            </div>
            
            <!-- Right Side Image -->
            <div class="w-full md:w-1/2 relative mt-10 md:mt-0">
                <!-- Background decorative elements for image -->
                <div class="absolute inset-0 bg-teal-200 rounded-full blur-3xl opacity-30 transform translate-x-10 -translate-y-10"></div>
                <img src="/images/doctor_hero.png" alt="Professional Doctor" class="relative z-10 w-full max-w-md mx-auto aspect-square object-cover rounded-3xl shadow-xl shadow-slate-200/50 border-8 border-white transform hover:scale-[1.01] transition duration-500">
            </div>
        </div>
    </section>

    <!-- Departments Section -->
    <section class="max-w-6xl mx-auto px-4 md:px-8 py-20 mb-10">
        
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-4">Our Departments</h2>
            <p class="text-lg text-slate-500 max-w-2xl mx-auto font-light">We provide quality care for your health with specialized treatments designed exactly for you.</p>
        </div>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            
            <!-- Skin Care -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] border border-slate-100 transition-all duration-300 transform hover:-translate-y-1 flex flex-col">
                <div class="w-full h-56 relative overflow-hidden">
                    <img src="/images/skin_care.png" alt="Skin Care Treatments" class="w-full h-full object-cover">
                    <!-- Overlay gradient for smooth text blending if needed -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                </div>
                <div class="p-8 flex-grow flex flex-col text-center md:text-left">
                    <h3 class="text-2xl font-bold text-slate-800 mb-3">Skin Care</h3>
                    <p class="text-slate-500 leading-relaxed font-light mb-8 flex-grow text-sm md:text-base">
                        Advanced treatments for healthy, glowing, and youthful skin tailored to your individual needs.
                    </p>
                    <a href="/doctors?department=skin" class="inline-flex items-center justify-center md:justify-start text-teal-600 hover:text-teal-700 font-semibold text-lg group w-fit transition-colors mx-auto md:mx-0">
                        Learn More 
                        <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </a>
                </div>
            </div>

            <!-- Hair Care -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] border border-slate-100 transition-all duration-300 transform hover:-translate-y-1 flex flex-col">
                <div class="w-full h-56 relative overflow-hidden">
                    <img src="/images/hair_care.png" alt="Hair Care Solutions" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                </div>
                <div class="p-8 flex-grow flex flex-col text-center md:text-left">
                    <h3 class="text-2xl font-bold text-slate-800 mb-3">Hair Care</h3>
                    <p class="text-slate-500 leading-relaxed font-light mb-8 flex-grow text-sm md:text-base">
                        Top solutions for scalp health, hair loss prevention, and restoration for thicker, stronger hair.
                    </p>
                    <a href="/doctors?department=hair" class="inline-flex items-center justify-center md:justify-start text-teal-600 hover:text-teal-700 font-semibold text-lg group w-fit transition-colors mx-auto md:mx-0">
                        Learn More 
                        <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </a>
                </div>
            </div>

            <!-- Dentistry -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] border border-slate-100 transition-all duration-300 transform hover:-translate-y-1 flex flex-col">
                <div class="w-full h-56 relative overflow-hidden">
                    <img src="/images/dentistry.png" alt="Professional Dentistry" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                </div>
                <div class="p-8 flex-grow flex flex-col text-center md:text-left">
                    <h3 class="text-2xl font-bold text-slate-800 mb-3">Dentistry</h3>
                    <p class="text-slate-500 leading-relaxed font-light mb-8 flex-grow text-sm md:text-base">
                        Professional dental care for a bright, clean, and healthy smile with modern techniques.
                    </p>
                    <a href="/doctors?department=dentistry" class="inline-flex items-center justify-center md:justify-start text-teal-600 hover:text-teal-700 font-semibold text-lg group w-fit transition-colors mx-auto md:mx-0">
                        Learn More 
                        <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </a>
                </div>
            </div>

        </div>
    </section>

</main>

<%- include('partials/footer') %>
