<!-- Navbar -->
<nav class="bg-white shadow-sm border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 md:px-8 py-4 flex justify-between items-center">

    <!-- Logo -->
    <a href="/" class="text-2xl font-bold text-teal-500 hover:text-teal-600 transition">
      SkinCare Clinic
    </a>

    <!-- Links -->
    <div class="hidden md:flex gap-6 font-medium text-slate-600 text-sm">
      <a href="/" class="hover:text-teal-500 transition">Home</a>
      <a href="/doctors" class="hover:text-teal-500 transition">Doctors</a>
      <a href="/services" class="hover:text-teal-500 transition">Services</a>
      <a href="/about" class="hover:text-teal-500 transition">About</a>
    </div>

    <!-- Auth -->
    <div class="flex gap-4">
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/dashboard" class="px-5 py-2 rounded-lg bg-teal-500 text-white font-medium text-sm hover:bg-teal-600 shadow-sm transition">
          Dashboard
        </a>
      <% } else { %>
        <a href="/auth/login" class="px-5 py-2 rounded-lg border border-teal-500 text-teal-500 font-medium text-sm hover:bg-teal-50 transition">
          Sign In
        </a>
        <a href="/auth/signup" class="px-5 py-2 rounded-lg bg-teal-500 text-white font-medium text-sm hover:bg-teal-600 shadow-sm transition hidden md:inline-block">
          Register
        </a>
      <% } %>
    </div>

  </div>
</nav>
