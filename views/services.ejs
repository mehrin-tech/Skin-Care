<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="flex-grow w-full pb-24 relative bg-slate-50/30">
    <!-- Header Section with gradient -->
    <section class="bg-gradient-to-b from-teal-50/70 to-transparent pt-16 pb-12 mb-10 overflow-hidden relative">
        <div class="max-w-7xl mx-auto px-4 md:px-8 relative z-10 flex flex-col md:flex-row items-center justify-between">
            <div class="text-left w-full md:w-2/3">
                <span class="inline-block py-1.5 px-4 rounded-full bg-white text-teal-600 text-sm font-semibold tracking-wide mb-4 border border-teal-100 shadow-sm">
                    Clinical Expertise
                </span>
                <h1 class="text-4xl md:text-5xl font-bold text-slate-800 mb-4 tracking-tight">Our Services</h1>
                <p class="text-lg text-slate-500 max-w-xl font-light">We provide premium quality care for your health with specialized, state-of-the-art treatments designed exactly for you.</p>
            </div>
            
            <div class="w-full md:w-1/3 mt-8 md:mt-0 text-left md:text-right">
                <a href="/auth/login" class="px-8 py-3.5 rounded-lg bg-teal-500 hover:bg-teal-600 text-white font-semibold shadow-lg shadow-teal-500/30 transition transform hover:-translate-y-0.5 inline-block">
                    Schedule Appointment
                </a>
            </div>
        </div>
        <!-- Decorative bg elements -->
        <div class="absolute top-0 right-0 -mt-20 -mr-20 w-96 h-96 bg-teal-100 rounded-full blur-[100px] opacity-40"></div>
    </section>

    <!-- Services Categories wrapper -->
    <section class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 xl:gap-10">
            
            <!-- Skin Care Category -->
            <div class="bg-white rounded-[24px] p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 flex flex-col">
                <div class="flex items-center gap-4 mb-8 pb-6 border-b border-slate-50">
                    <div class="text-teal-500 bg-teal-50/80 w-14 h-14 rounded-2xl flex items-center justify-center border border-teal-100/50 shrink-0">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold text-slate-800">Skin Care</h2>
                        <p class="text-sm text-slate-500 font-light mt-1">Advanced aesthetic therapies</p>
                    </div>
                </div>

                <div class="flex flex-col gap-5 flex-grow">
                    <!-- Acne Treatment -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/acne_treatment.png" alt="Acne Treatment" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Acne Treatment</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Effective solutions for clear skin</p>
                        </div>
                    </div>
                    <!-- Chemical Peels -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/chemical_peel.png" alt="Chemical Peels" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Chemical Peels</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Deep exfoliation for skin renewal</p>
                        </div>
                    </div>
                    <!-- Laser Therapy -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/laser_therapy.png" alt="Laser Therapy" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Laser Therapy</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Advanced laser cosmetic routines</p>
                        </div>
                    </div>
                    <!-- Hydrafacial -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/hydrafacial.png" alt="Hydrafacial" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Hydrafacial</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Cleansing, extraction, and hydration</p>
                        </div>
                    </div>
                    <!-- Anti-aging Treatment -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/anti_aging.png" alt="Anti-aging Treatment" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Anti-aging</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Regain your youthful glow</p>
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-slate-50 text-center">
                    <a href="/doctors?department=skin" class="inline-flex items-center text-teal-600 hover:text-teal-700 font-semibold text-lg transition-colors group">
                        View Doctors 
                        <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </a>
                </div>
            </div>

            <!-- Hair Care Category -->
            <div class="bg-white rounded-[24px] p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 flex flex-col mt-4 md:mt-0">
                <div class="flex items-center gap-4 mb-8 pb-6 border-b border-slate-50">
                    <div class="text-teal-500 bg-teal-50/80 w-14 h-14 rounded-2xl flex items-center justify-center border border-teal-100/50 shrink-0">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold text-slate-800">Hair Care</h2>
                        <p class="text-sm text-slate-500 font-light mt-1">Clinical restoration & therapies</p>
                    </div>
                </div>

                <div class="flex flex-col gap-5 flex-grow">
                    <!-- Hair Loss Treatment -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/hair_loss.png" alt="Hair Loss Treatment" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Hair Loss Treatment</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Prevent and reverse hair thinning</p>
                        </div>
                    </div>
                    <!-- Hair Transplant -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/hair_transplant.png" alt="Hair Transplant" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Hair Transplant</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Permanent, natural-looking restoration</p>
                        </div>
                    </div>
                    <!-- PRP Therapy -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/prp_therapy.png" alt="PRP Therapy" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">PRP Therapy</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Platelet-rich plasma stimulation</p>
                        </div>
                    </div>
                    <!-- Scalp Treatment -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/scalp_treatment.png" alt="Scalp Treatment" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Scalp Treatment</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Deep nourishment and balancing</p>
                        </div>
                    </div>
                    <!-- Hair Spa -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/hair_spa.png" alt="Hair Spa" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Hair Spa</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Luxury hair conditioning and repair</p>
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-slate-50 text-center">
                    <a href="/doctors?department=hair" class="inline-flex items-center text-teal-600 hover:text-teal-700 font-semibold text-lg transition-colors group">
                        View Doctors 
                        <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </a>
                </div>
            </div>

            <!-- Dentistry Category -->
            <div class="bg-white rounded-[24px] p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 flex flex-col mt-4 lg:mt-0">
                <div class="flex items-center gap-4 mb-8 pb-6 border-b border-slate-50">
                    <div class="text-teal-500 bg-teal-50/80 w-14 h-14 rounded-2xl flex items-center justify-center border border-teal-100/50 shrink-0">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold text-slate-800">Dentistry</h2>
                        <p class="text-sm text-slate-500 font-light mt-1">Rebuilding secure, healthy smiles</p>
                    </div>
                </div>

                <div class="flex flex-col gap-5 flex-grow">
                    <!-- Teeth Whitening -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/teeth_whitening.png" alt="Teeth Whitening" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Teeth Whitening</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Professional brightness and stain removal</p>
                        </div>
                    </div>
                    <!-- Dental Implants -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/dental_implants.png" alt="Dental Implants" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Dental Implants</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Secure and lasting tooth replacements</p>
                        </div>
                    </div>
                    <!-- Orthodontics -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/orthodontics.png" alt="Orthodontics" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Orthodontics</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Braces and clear aligner therapies</p>
                        </div>
                    </div>
                    <!-- Veneers -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/veneers.png" alt="Veneers" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Veneers</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Perfect shape with porcelain shells</p>
                        </div>
                    </div>
                    <!-- Root Canal -->
                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-[0_8px_30px_rgb(20,184,166,0.12)] transition-all duration-300 transform hover:-translate-y-1">
                        <img src="/images/root_canal.png" alt="Root Canal" class="w-full h-36 object-cover">
                        <div class="p-4">
                            <h3 class="font-semibold text-slate-800 mb-1">Root Canal</h3>
                            <p class="text-slate-500 text-xs font-light truncate">Painless preservation of natural teeth</p>
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-slate-50 text-center">
                    <a href="/doctors?department=dentistry" class="inline-flex items-center text-teal-600 hover:text-teal-700 font-semibold text-lg transition-colors group">
                        View Doctors 
                        <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </a>
                </div>
            </div>

        </div>
    </section>
</main>

<%- include('partials/footer') %>
