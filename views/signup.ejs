<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="flex-grow flex items-center justify-center p-4 w-full py-12 md:py-16">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-sm p-8 md:p-10 border border-slate-200">
        
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-slate-800 tracking-tight">Create Account</h1>
            <p class="text-slate-500 mt-2 text-sm font-medium">Join us to manage your health securely</p>
        </div>

        <% if (typeof message !== 'undefined' && message) { %>
            <div class="mb-6 bg-yellow-50 border border-yellow-200 text-yellow-600 px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-3">
                <span><%= message %></span>
            </div>
        <% } %>

        <form action="/auth/signup" method="POST" class="space-y-4" novalidate>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Full Name</label>
                <input type="text" name="name" required placeholder="John Doe"
                    value="<%= typeof oldInput !== 'undefined' && oldInput.name ? oldInput.name : '' %>"
                    class="w-full px-4 py-2 border <%= typeof errors !== 'undefined' && errors.name ? 'border-red-500' : 'border-slate-200 focus:border-teal-500' %> rounded-lg outline-none text-sm bg-slate-50 focus:bg-white transition">
                <% if (typeof errors !== 'undefined' && errors.name) { %>
                    <p class="text-red-500 text-xs mt-1"><%= errors.name %></p>
                <% } %>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Email Address</label>
                <input type="email" name="email" required placeholder="john@example.com"
                    value="<%= typeof oldInput !== 'undefined' && oldInput.email ? oldInput.email : '' %>"
                    class="w-full px-4 py-2 border <%= typeof errors !== 'undefined' && errors.email ? 'border-red-500' : 'border-slate-200 focus:border-teal-500' %> rounded-lg outline-none text-sm bg-slate-50 focus:bg-white transition">
                <% if (typeof errors !== 'undefined' && errors.email) { %>
                    <p class="text-red-500 text-xs mt-1"><%= errors.email %></p>
                <% } %>
            </div>
            
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Password</label>
                <input type="password" name="password" required placeholder="••••••••"
                    class="w-full px-4 py-2 border <%= typeof errors !== 'undefined' && errors.password ? 'border-red-500' : 'border-slate-200 focus:border-teal-500' %> rounded-lg outline-none text-sm bg-slate-50 focus:bg-white transition">
                <% if (typeof errors !== 'undefined' && errors.password) { %>
                    <p class="text-red-500 text-xs mt-1"><%= errors.password %></p>
                <% } %>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Confirm Password</label>
                <input type="password" name="confirmPassword" required placeholder="••••••••"
                    class="w-full px-4 py-2 border <%= typeof errors !== 'undefined' && errors.confirmPassword ? 'border-red-500' : 'border-slate-200 focus:border-teal-500' %> rounded-lg outline-none text-sm bg-slate-50 focus:bg-white transition">
                <% if (typeof errors !== 'undefined' && errors.confirmPassword) { %>
                    <p class="text-red-500 text-xs mt-1"><%= errors.confirmPassword %></p>
                <% } %>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Account Role</label>
                <select name="role" required class="w-full px-4 py-2 border border-slate-200 rounded-lg outline-none text-sm bg-slate-50 focus:bg-white transition">
                    <option value="user" <%= typeof oldInput !== 'undefined' && oldInput.role === 'user' ? 'selected' : '' %>>Patient</option>
                    <option value="doctor" <%= typeof oldInput !== 'undefined' && oldInput.role === 'doctor' ? 'selected' : '' %>>Doctor</option>
                </select>
            </div>

            <button type="submit" class="w-full py-3 mt-4 bg-teal-500 hover:bg-teal-600 text-white font-semibold rounded-lg shadow-sm transition text-sm">
                Register
            </button>
        </form>

        <p class="mt-6 text-center text-sm text-slate-500">
            Already have an account? 
            <a href="/auth/login" class="text-teal-500 hover:text-teal-600 font-medium">Log in</a>
        </p>
    </div>
</main>

<script src="/js/validation.js"></script>

<%- include('partials/footer') %>
